	name = "army_headquarters_entity"
	pdxmesh = "generic_army_headquarters_mesh"

	default_state = "idle"
	state = { name = "attack"			animation = "charge_pistol" 					animation_blend_time = 0.0  animation_speed = 1.0 looping = no next_state = "attack" chance = 2 propagate_state = { rifle1 = "idle" } }
	state = { name = "attack"			animation = "charge_pistol_shoot" 			animation_blend_time = 0.0  animation_speed = 1.0 looping = no next_state = "attack" chance = 1 propagate_state = { rifle2 = "idle" } }
	#state = { name = "defend"			animation = "attack01" 			animation_blend_time = 0.3  animation_speed = 1.0 chance = 1}
