	attach = { 	name = "rifle3"	mid_back_node = "HOL_army_weapon_pistol_long_idle_entity" }

	attach = { 	name = "pencil"			Right_Hand_node_2 = "pencil_entity" }
	attach = { 	name = "clipboard"	Left_Hand_node_2 = "clipboard_entity" }
	attach = { 	name = "binoculars"	Left_Hand_node_3 = "binoculars_entity" }
