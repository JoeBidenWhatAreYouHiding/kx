#Webley Revolver#####################################

entity = {
	name = "ENG_army_weapon_pistol_left_entity"
	pdxmesh = "ENG_army_weapon_pistol_mesh"
	scale = 1
}

entity = {
	name = "ENG_army_weapon_pistol_long_idle_entity"
	pdxmesh = "ENG_army_weapon_pistol_mesh"
	scale = 1
}

entity = {
	name = "ENG_army_weapon_pistol_right_entity"
	pdxmesh = "ENG_army_weapon_pistol_mesh"
	scale = 0.9

	get_state_from_parent = yes
	default_state = "idle"
	state = { name = "idle" }
	state = { name = "move" }

	state = { name = "attack"	animation = "attack"
		event = { time = 1.5 node="muzzle" particle = "pistol_muzzle_particle"  keep_particle = yes   light = "rifle_muzzle_flash" sound = { soundeffect = "pistol_revolver_fire" } }
	}

#two-handed pistol stance
	state = { name = "defend"
		event = { time = 0.2 node="muzzle" particle = "pistol_muzzle_particle"  keep_particle = yes   light = "rifle_muzzle_flash" sound = { soundeffect = "pistol_revolver_fire" } }
		event = { time = 0.87 node="muzzle" particle = "pistol_muzzle_particle"  keep_particle = yes   light = "rifle_muzzle_flash" }
		event = { time = 1 node="muzzle" particle = "mg_muzzle_smoke_particle"  keep_particle = yes   light = "rifle_muzzle_flash" sound = { soundeffect = "pistol_revolver_fire" } }
	}
}

